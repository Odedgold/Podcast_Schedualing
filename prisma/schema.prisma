generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model School {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Defines a dynamic form field + how it affects matching
model CustomFieldDefinition {
  id             String         @id @default(cuid())
  label          String                        // shown in form & admin
  fieldKey       String         @unique        // internal key, e.g. "english_level"
  fieldType      FieldType      @default(TEXT)
  options        String[]       @default([])   // for SELECT / MULTISELECT
  placeholder    String?                       // hint text in form
  isRequired     Boolean        @default(false)
  isActive       Boolean        @default(true)
  sortOrder      Int            @default(0)
  // Matching config
  matchingMode   MatchingMode   @default(OFF)  // OFF | PREFERRED | MANDATORY
  matchingType   MatchingType   @default(SAME_VALUE) // how to compare two values
  matchingWeight Int            @default(3)    // score bonus when PREFERRED matches
  createdAt      DateTime       @default(now())
  responses      CustomFieldResponse[]
}

enum FieldType {
  TEXT
  NUMBER
  SELECT
  MULTISELECT
}

enum MatchingMode {
  OFF
  PREFERRED
  MANDATORY
}

enum MatchingType {
  SAME_VALUE       // both must have identical value
  DIFFERENT_VALUE  // both must have different value
  NUMERIC_GAP      // |a - b| <= matchingWeight (weight reused as max gap)
  ANY_VALUE        // just having any value is enough (e.g. "filled in")
}

model Participant {
  id               String            @id @default(cuid())
  submissionToken  String            @unique @default(cuid())
  // Core fixed fields (always present)
  fullName         String
  email            String
  phone            String?
  schoolName       String
  city             String
  country          String
  detectedTz       String
  confirmedTz      String
  status           ParticipantStatus @default(PENDING)
  submittedAt      DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  // All other data lives in customFields
  customFields     CustomFieldResponse[]
  availability     AvailabilitySlot[]
  matchMembers     MatchMember[]
}

enum ParticipantStatus {
  PENDING
  MATCHED
  INACTIVE
}

model CustomFieldResponse {
  id            String                @id @default(cuid())
  participant   Participant           @relation(fields: [participantId], references: [id], onDelete: Cascade)
  participantId String
  field         CustomFieldDefinition @relation(fields: [fieldId], references: [id])
  fieldId       String
  value         String
  @@unique([participantId, fieldId])
}

model AvailabilitySlot {
  id            String      @id @default(cuid())
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  participantId String
  dayOfWeek     Int         // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime     String      // "HH:MM"
  endTime       String      // "HH:MM"
  createdAt     DateTime    @default(now())
  @@unique([participantId, dayOfWeek, startTime])
  @@index([participantId])
}

model Match {
  id                 String      @id @default(cuid())
  matchType          MatchType
  status             MatchStatus @default(DRAFT)
  scheduledStartUtc  DateTime
  scheduledEndUtc    DateTime
  adminNotes         String?
  systemNotes        String?
  approvedAt         DateTime?
  approvedBy         String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  members            MatchMember[]
}

enum MatchType {
  PAIR
  GROUP
}

enum MatchStatus {
  DRAFT
  APPROVED
  REJECTED
  CANCELLED
}

model MatchMember {
  id            String      @id @default(cuid())
  match         Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId       String
  participant   Participant @relation(fields: [participantId], references: [id])
  participantId String
  role          MemberRole  @default(PARTICIPANT)
  @@unique([matchId, participantId])
}

enum MemberRole {
  PARTICIPANT
  FACILITATOR
}
